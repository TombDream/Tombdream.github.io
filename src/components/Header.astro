---
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/blog', label: '文章' },
  { href: '/about', label: '关于' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-ink-50/80 dark:bg-ink-950/80 backdrop-blur-md border-b border-ink-200/60 dark:border-ink-800/60">
  <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-serif font-bold text-lg text-ink-900 dark:text-ink-50 tracking-tight hover:opacity-80 transition-opacity">
      BLOG
    </a>

    <!-- Nav -->
    <nav class="hidden sm:flex items-center gap-6">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/' ? currentPath === '/' : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class={`text-sm transition-colors ${
              isActive
                ? 'text-ink-900 dark:text-ink-50 font-medium'
                : 'text-ink-500 dark:text-ink-400 hover:text-ink-900 dark:hover:text-ink-50'
            }`}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <!-- Search -->
      <button
        id="search-btn"
        class="p-2 text-ink-500 dark:text-ink-400 hover:text-ink-900 dark:hover:text-ink-50 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800 transition-all"
        aria-label="搜索"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/>
        </svg>
      </button>

      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        class="p-2 text-ink-500 dark:text-ink-400 hover:text-ink-900 dark:hover:text-ink-50 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800 transition-all"
        aria-label="切换主题"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0z"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998z"/>
        </svg>
      </button>

      <!-- Mobile menu -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden p-2 text-ink-500 dark:text-ink-400 hover:text-ink-900 dark:hover:text-ink-50 rounded-lg hover:bg-ink-100 dark:hover:bg-ink-800 transition-all"
        aria-label="菜单"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-ink-200/60 dark:border-ink-800/60">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <a href={href} class="text-sm text-ink-600 dark:text-ink-300 hover:text-ink-900 dark:hover:text-ink-50 transition-colors">
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- Search overlay -->
<div id="search-overlay" class="fixed inset-0 z-[100] hidden">
  <div class="absolute inset-0 bg-ink-950/40 dark:bg-ink-950/60 backdrop-blur-sm" id="search-backdrop"></div>
  <div class="relative max-w-xl mx-auto mt-20 mx-4 sm:mx-auto">
    <div class="bg-white dark:bg-ink-900 rounded-2xl border border-ink-200 dark:border-ink-700 overflow-hidden">
      <div class="flex items-center gap-3 px-5 py-4 border-b border-ink-100 dark:border-ink-800">
        <svg class="w-4 h-4 text-ink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="搜索文章..."
          class="flex-1 bg-transparent text-ink-800 dark:text-ink-100 placeholder:text-ink-400 outline-none text-sm"
          autocomplete="off"
        />
        <kbd class="text-xs text-ink-400 border border-ink-200 dark:border-ink-700 rounded px-1.5 py-0.5">ESC</kbd>
      </div>
      <div id="search-results" class="max-h-80 overflow-y-auto p-2">
        <p class="text-center text-sm text-ink-400 py-8">输入关键词开始搜索</p>
      </div>
    </div>
  </div>
</div>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Search overlay
  const searchBtn = document.getElementById('search-btn');
  const searchOverlay = document.getElementById('search-overlay');
  const searchBackdrop = document.getElementById('search-backdrop');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;

  function openSearch() {
    searchOverlay?.classList.remove('hidden');
    setTimeout(() => searchInput?.focus(), 100);
  }
  function closeSearch() {
    searchOverlay?.classList.add('hidden');
  }

  searchBtn?.addEventListener('click', openSearch);
  searchBackdrop?.addEventListener('click', closeSearch);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeSearch();
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); openSearch(); }
  });

  // Simple client-side search (uses /search-index.json generated at build time)
  searchInput?.addEventListener('input', async (e) => {
    const query = (e.target as HTMLInputElement).value.trim();
    const resultsEl = document.getElementById('search-results');
    if (!resultsEl) return;
    if (!query) {
      resultsEl.innerHTML = '<p class="text-center text-sm text-ink-400 py-8">输入关键词开始搜索</p>';
      return;
    }
    // Simple fetch-based search
    try {
      const res = await fetch('/search-index.json');
      const posts = await res.json();
      const results = posts.filter((p: any) =>
        p.title.includes(query) || p.description.includes(query) || p.tags.join(' ').includes(query)
      ).slice(0, 8);
      if (results.length === 0) {
        resultsEl.innerHTML = '<p class="text-center text-sm text-ink-400 py-8">未找到相关文章</p>';
        return;
      }
      resultsEl.innerHTML = results.map((p: any) => `
        <a href="${p.url}" class="block px-3 py-3 rounded-xl hover:bg-ink-50 dark:hover:bg-ink-800 transition-colors">
          <div class="text-sm font-medium text-ink-800 dark:text-ink-100 mb-1">${p.title}</div>
          <div class="text-xs text-ink-400 dark:text-ink-500 line-clamp-1">${p.description}</div>
        </a>
      `).join('');
    } catch {
      resultsEl.innerHTML = '<p class="text-center text-sm text-ink-400 py-8">搜索暂时不可用</p>';
    }
  });
</script>
