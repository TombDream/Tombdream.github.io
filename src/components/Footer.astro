---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-200/60 dark:border-ink-800/60 mt-20">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-sm text-ink-400 dark:text-ink-500">
        &copy; {year} · 用文字记录生活与思考
      </div>
      <div class="flex items-center gap-5">
        <a href="/rss.xml" class="text-sm text-ink-400 dark:text-ink-500 hover:text-ink-700 dark:hover:text-ink-200 transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
