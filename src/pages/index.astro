---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts.find(p => p.data.featured) || posts[0];
const recent = posts.filter(p => p.slug !== featured?.slug).slice(0, 6);

const categories = [...new Set(posts.map(p => p.data.category))];
---

<BaseLayout title="我的博客 — 技术与生活">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Hero Section -->
    <section class="py-20 sm:py-28 fade-in">
      <div class="max-w-2xl">
        <p class="text-sm font-medium tracking-widest uppercase text-ink-400 dark:text-ink-500 mb-4">欢迎来到</p>
        <h1 class="font-serif text-4xl sm:text-5xl font-bold text-ink-900 dark:text-ink-50 leading-tight tracking-tight mb-6">
          我的数字花园<span class="text-ink-300 dark:text-ink-700">.</span>
        </h1>
        <p class="text-lg text-ink-500 dark:text-ink-400 leading-relaxed mb-8 max-w-lg">
          在这里记录技术探索、生活感悟与随手拍下的世界。愿每一行文字都值得停留。
        </p>
        <div class="flex items-center gap-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 bg-ink-900 dark:bg-ink-50 text-ink-50 dark:text-ink-900 px-5 py-2.5 rounded-full text-sm font-medium hover:opacity-80 transition-opacity"
          >
            浏览文章
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
          <a href="/about" class="text-sm text-ink-500 dark:text-ink-400 hover:text-ink-900 dark:hover:text-ink-50 transition-colors underline underline-offset-4 decoration-ink-300">
            了解我
          </a>
        </div>
      </div>
    </section>

    <!-- Stats bar -->
    <div class="flex items-center gap-8 py-6 border-y border-ink-200/60 dark:border-ink-800/60 mb-16 fade-in fade-in-delay-1">
      <div>
        <div class="text-2xl font-serif font-bold text-ink-900 dark:text-ink-50">{posts.length}</div>
        <div class="text-xs text-ink-400 dark:text-ink-500 mt-0.5">篇文章</div>
      </div>
      <div class="h-8 w-px bg-ink-200 dark:bg-ink-800"></div>
      <div>
        <div class="text-2xl font-serif font-bold text-ink-900 dark:text-ink-50">{categories.length}</div>
        <div class="text-xs text-ink-400 dark:text-ink-500 mt-0.5">个分类</div>
      </div>
      <div class="h-8 w-px bg-ink-200 dark:bg-ink-800"></div>
      <div class="flex items-center gap-2 flex-wrap">
        {categories.slice(0, 4).map(cat => (
          <a
            href={`/category/${cat}`}
            class="text-xs px-2.5 py-1 rounded-full bg-ink-100 dark:bg-ink-800 text-ink-600 dark:text-ink-300 hover:bg-ink-200 dark:hover:bg-ink-700 transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>

    <!-- Featured post -->
    {featured && (
      <section class="mb-16 fade-in fade-in-delay-2">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px flex-1 bg-ink-200 dark:bg-ink-800"></div>
          <span class="text-xs font-medium tracking-wider uppercase text-ink-400 dark:text-ink-500">精选文章</span>
          <div class="h-px flex-1 bg-ink-200 dark:bg-ink-800"></div>
        </div>
        <a href={`/blog/${featured.slug}`} class="group block">
          <div class="grid sm:grid-cols-2 gap-8 items-center bg-white dark:bg-ink-900 rounded-2xl p-8 border border-ink-200/60 dark:border-ink-800/60 card-hover">
            {featured.data.heroImage ? (
              <div class="overflow-hidden rounded-xl aspect-[4/3]">
                <img
                  src={featured.data.heroImage}
                  alt={featured.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            ) : (
              <div class="overflow-hidden rounded-xl aspect-[4/3] bg-ink-100 dark:bg-ink-800 flex items-center justify-center">
                <span class="font-serif text-6xl text-ink-300 dark:text-ink-600">"</span>
              </div>
            )}
            <div>
              <span class="text-xs font-medium tracking-wider uppercase text-ink-400 dark:text-ink-500">{featured.data.category}</span>
              <h2 class="font-serif text-2xl font-bold text-ink-900 dark:text-ink-50 mt-3 mb-4 leading-tight group-hover:text-ink-600 dark:group-hover:text-ink-300 transition-colors">
                {featured.data.title}
              </h2>
              <p class="text-ink-500 dark:text-ink-400 leading-relaxed mb-5 line-clamp-3">{featured.data.description}</p>
              <div class="flex items-center gap-3 text-sm text-ink-400 dark:text-ink-500">
                <FormattedDate date={featured.data.pubDate} />
              </div>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- Recent posts grid -->
    {recent.length > 0 && (
      <section class="mb-20 fade-in fade-in-delay-3">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-serif text-xl font-bold text-ink-900 dark:text-ink-50">最新文章</h2>
          <a href="/blog" class="text-sm text-ink-400 dark:text-ink-500 hover:text-ink-800 dark:hover:text-ink-200 transition-colors flex items-center gap-1">
            全部文章
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {recent.map((post) => (
            <a href={`/blog/${post.slug}`} class="group block">
              <article class="h-full bg-white dark:bg-ink-900 rounded-xl border border-ink-200/60 dark:border-ink-800/60 overflow-hidden card-hover">
                {post.data.heroImage ? (
                  <div class="overflow-hidden aspect-[16/9]">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                ) : (
                  <div class="aspect-[16/9] bg-ink-50 dark:bg-ink-800 flex items-center justify-center">
                    <span class="font-serif text-4xl text-ink-200 dark:text-ink-700">"</span>
                  </div>
                )}
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-xs text-ink-400 dark:text-ink-500 font-medium">{post.data.category}</span>
                    <span class="text-ink-200 dark:text-ink-700">·</span>
                    <FormattedDate date={post.data.pubDate} />
                  </div>
                  <h3 class="font-serif font-bold text-ink-900 dark:text-ink-50 leading-snug mb-2 group-hover:text-ink-600 dark:group-hover:text-ink-300 transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-ink-500 dark:text-ink-400 line-clamp-2 leading-relaxed">
                    {post.data.description}
                  </p>
                </div>
              </article>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</BaseLayout>
