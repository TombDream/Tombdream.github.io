---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="关于我 — 博客" description="了解博主的个人介绍">
  <div class="max-w-2xl mx-auto px-6 py-20">

    <!-- Avatar & name -->
    <div class="flex items-start gap-6 mb-12">
      <div class="w-20 h-20 rounded-full bg-ink-200 dark:bg-ink-700 flex items-center justify-center text-3xl font-serif font-bold text-ink-500 dark:text-ink-300 flex-shrink-0">
        你
      </div>
      <div>
        <h1 class="font-serif text-3xl font-bold text-ink-900 dark:text-ink-50 mb-2 tracking-tight">你好，我是 XXX</h1>
        <p class="text-ink-400 dark:text-ink-500 text-sm">开发者 · 摄影爱好者 · 生活记录者</p>
      </div>
    </div>

    <div class="prose prose-ink dark:prose-invert">
      <p>
        欢迎来到我的个人博客。这里是我的数字花园，记录着我在技术探索、日常生活和随手思考中留下的痕迹。
      </p>
      <p>
        我热爱 Android 开发，喜欢研究用户体验，也时常会被一本好书、一张好照片或一段好音乐深深打动。
      </p>
      <h2>我在写什么</h2>
      <ul>
        <li><strong>技术笔记</strong> — Android、Web 开发心得与踩坑记录</li>
        <li><strong>产品思考</strong> — 对产品设计和用户体验的随想</li>
        <li><strong>生活随笔</strong> — 日常观察、书影音推荐</li>
      </ul>
      <h2>联系我</h2>
      <p>
        如果你想交流，可以通过以下方式找到我：
      </p>
    </div>

    <!-- Social links -->
    <div class="flex gap-4 mt-8">
      <a href="https://github.com/YOUR_USERNAME" target="_blank" rel="noopener"
         class="flex items-center gap-2 px-4 py-2 rounded-xl border border-ink-200 dark:border-ink-700 text-sm text-ink-600 dark:text-ink-300 hover:bg-ink-100 dark:hover:bg-ink-800 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2z"/></svg>
        GitHub
      </a>
      <a href="mailto:your@email.com"
         class="flex items-center gap-2 px-4 py-2 rounded-xl border border-ink-200 dark:border-ink-700 text-sm text-ink-600 dark:text-ink-300 hover:bg-ink-100 dark:hover:bg-ink-800 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
        邮件
      </a>
    </div>

  </div>
</BaseLayout>
